<?xml version="1.0"?>
<launch>
  <include file="$(find freenect_launch)/launch/freenect.launch">
    <arg name="depth_registration" value="true" />
  </include>

  <node pkg="depthimage_to_laserscan" type="depthimage_to_laserscan" name="depthimage_to_laserscan" output="screen" respawn="true">
    <remap from="image"       to="/camera/depth_registered/image_raw"/>
    <remap from="camera_info" to="/camera/depth_registered/camera_info"/>
    <remap from="scan"        to="/scan"/>
    <param name="scan_height"     type="int"    value="5"/>    
    <param name="scan_time"       type="double" value="0.033"/> 
    <param name="range_min"       type="double" value="0.45"/> <param name="range_max"       type="double" value="10.0"/> <param name="output_frame_id" type="str"    value="camera_depth_frame"/>
  </node>

  <arg name="model" default="$(find autonomus_mobile_robot)/urdf/mobile_robot.urdf.xacro"/>
  <param name="robot_description" command="$(find xacro)/xacro $(arg model)" />
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"/>
  <node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui"/>
  
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find autonomus_mobile_robot)/config/amcl_nav.rviz"/>

  <node pkg="tf" type="static_transform_publisher" name="camera_optical" args="0 0 0.83 0 0 0 base_link camera_link 100" />

  <group ns="rtabmap">
    <node pkg="nodelet" type="nodelet" name="rgbd_sync" args="standalone rtabmap_sync/rgbd_sync" output="screen" respawn="true">
      <remap from="rgb/image"        to="/camera/rgb/image_rect_color"/>
      <remap from="depth/image"      to="/camera/depth_registered/image_raw"/>
      <remap from="rgb/camera_info"  to="/camera/rgb/camera_info"/>
      <remap from="rgbd_image"       to="rgbd_image"/>
      <param name="approx_sync" value="true"/>
    </node>

    <node pkg="rtabmap_odom" type="rgbd_odometry" name="rgbd_odometry" output="screen" respawn="true">
        <param name="frame_id" value="base_link"/>
        <param name="odom_frame_id" value="odom"/>
        <param name="max_depth" value="4.0"/> <param name="Reg/Strategy" value="0"/> 
        
        <param name="Vis/MinInliers" value="10"/>      <param name="Odom/ResetCountdown" value="1"/>  <remap from="rgb/image" to="/camera/rgb/image_rect_color"/>
        <remap from="depth/image" to="/camera/depth_registered/image_raw"/>
        <remap from="rgb/camera_info" to="/camera/rgb/camera_info"/>
    </node>
  </group>

  <node pkg="robot_pose_ekf" type="robot_pose_ekf" name="robot_pose_ekf" output="screen" respawn="true">
    <param name="output_frame" value="odom"/>
    <param name="base_footprint_frame" value="base_footprint"/>
    <param name="freq" value="30.0"/>
    <param name="sensor_timeout" value="2.0"/> 
    <param name="odom_used" value="true"/>  
    <param name="imu_used" value="false"/> 
     <param name="vo_used" value="true"/>
    
    <remap from="odom" to="/odom_data_quat"/>
    <remap from="vo" to="/vo_filtered"/>
    <remap from="imu_data" to="/imu/data_filtered"/>
  </node>

  <node pkg="rosserial_python" type="serial_node.py" name="serial_node" output="screen" respawn="true">
    <param name="port" value="/dev/ttyUSB0"/> <param name="baud" value="115200"/>
  </node>

  <node pkg="gmapping" type="slam_gmapping" name="gmapping" output="screen" respawn="true">
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame"  value="map"/>
    <rosparam command="load" file="$(find autonomus_mobile_robot)/config/gmapping_params.yaml" />
    
    <param name="maxUrange" value="9.0"/> <param name="maxRange" value="10.5"/>
  </node>

  <node pkg="my_robot_pkg" type="vo_filter.py" name="vo_filter" output="screen" respawn="true">
    <param name="max_age" value="0.5"/>
  </node>
  <node pkg="my_robot_pkg" type="ekf_odom_pub" name="ekf_odom_pub"/>

</launch>
